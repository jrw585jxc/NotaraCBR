{
  "name": "notara-cbr",
  "version": "1.0.0",
  "description": "NotaraCBR — A cinematic comic book reader",
  "author": "Notara",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.2.67",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "node-unrar-js": "^2.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "@electron/packager": "^18.3.5",
    "electron": "^31.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "wait-on": "^7.2.0"
  },
  "packagerConfig": {
    "name": "NotaraCBR",
    "out": "dist-electron",
    "overwrite": true,
    "ignore": [
      "^/src",
      "^/\\.git",
      "^/dist-electron",
      "^/\\.vscode",
      "^/node_modules/\\.cache"
    ]
  }
}
